# =============================================
# FotoUai Backend - .gitignore
# Stack: NestJS / TypeORM / Node.js
# =============================================

# Dependencies
/node_modules

# Build output
/dist
/build

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Tests & Coverage
/coverage
/.nyc_output

# Environment variables
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# IDEs & Editors
/.idea
/.vscode/*
!/.vscode/settings.json
!/.vscode/tasks.json
!/.vscode/launch.json
!/.vscode/extensions.json
.project
.classpath
.c9/
.settings/
*.launch
*.sublime-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Temp files
.temp
.tmp

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# TypeORM migrations (auto-generated, optional)
# /migrations

# Docker (optional)
docker-compose.override.yml
