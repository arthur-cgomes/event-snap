# GENERAL
NODE_ENV=local
PORT=3000

# JWT (Passport)
AUTH_SECRET=your-jwt-secret-min-32-characters-long
EXPIRE_IN=7200

# DATABASE (PostgreSQL)
TYPEORM_HOST=localhost
TYPEORM_PORT=5432
TYPEORM_USERNAME=postgres
TYPEORM_PASSWORD=postgres
TYPEORM_DATABASE=fotouai
TYPEORM_SSL=false
TYPEORM_CONNECTION=postgres
TYPEORM_SYNCHRONIZE=false
TYPEORM_ENTITIES=dist/**/*.entity.js

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# SUPABASE (Storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=uploads

# EMAIL DISPATCHER (container interno na infra-network)
DISPATCHER_EMAIL_URL=http://dispatcher-email:3000
DISPATCHER_FROM_EMAIL=noreply@fotouai.com.br

# STRIPE (Pagamentos)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# FIREBASE (Social Login)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-client-email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# TURNSTILE (CAPTCHA - Cloudflare)
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# FRONTEND
FRONTEND_URL=http://localhost:3001

# CORS
CORS_ORIGIN=http://localhost:3001
